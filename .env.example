# Trend-to-Content Automation Engine - Environment Configuration
# Copy this file to .env and fill in your actual values.
# Never commit your .env file to version control.

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Which LLM backend to use. Valid options: "gemini" or "openai"
LLM_PROVIDER=gemini

# ─── Google Gemini ────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=gemini
# Obtain your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=openai
# Obtain your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ─── Cloudflare Image Generation ─────────────────────────────────────────────
# API key for the Cloudflare Worker image generation endpoint
# Endpoint: https://llm-chat-app-template.yaajnusubramanian.workers.dev/api/generate
CLOUDFLARE_API_KEY=your-cloudflare-api-key-here
